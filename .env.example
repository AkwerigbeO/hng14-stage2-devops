# Deployment Environment Configuration

# Frontend Settings
PORT=3000
# In Docker Compose, the API container is named 'api'
API_URL=http://api:8000

# Backend & Worker Settings
# Connects to the Redis container named 'redis'
REDIS_HOST=redis
REDIS_PORT=6379 
# Leave password blank for the default redis:7-alpine image, or set one if you configure redis to require it
REDIS_PASSWORD=

# Testing Environment configuration (For GitHub Actions)
# TESTING=true 
